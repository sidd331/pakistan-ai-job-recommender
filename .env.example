# =============================================================================
# Job Recommendation Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values.
# The app works with defaults for local development; optional services
# (Google OAuth, Email) are gracefully disabled when not configured.
# =============================================================================

# Flask
SECRET_KEY=change-me-to-a-random-string-in-production
FLASK_DEBUG=true

# Google OAuth 2.0 (optional — email/password auth works without these)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email Notifications via SMTP (optional — alerts disabled without these)
# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Matching engine
MATCH_THRESHOLD=70
